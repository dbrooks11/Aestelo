ARG PYTHON_VERSION=3.13

FROM python:${PYTHON_VERSION}-slim-bookworm AS dev

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_PYTHON_DOWNLOADS=0

WORKDIR /app

COPY --from=ghcr.io/astral-sh/uv:latest /uv /bin/uv

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    build-essential \
    cmake \
    git \
    libjpeg-dev \
    zlib1g-dev \
    libvips-dev \
    && rm -rf /var/lib/apt/lists/*

RUN git clone -b v3.3.2 https://github.com/microsoft/mimalloc.git /mimalloc \
    && cd /mimalloc && mkdir build && cd build \
    && cmake .. && make && make install \
    && ldconfig \
    && rm -rf /mimalloc

COPY pyproject.toml uv.lock ./

RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --all-extras

COPY . .

ENV PATH="/app/.venv/bin:$PATH" \
    LD_PRELOAD="/usr/local/lib/libmimalloc.so.3" \
    VIRTUAL_ENV="/app/.venv" \
    UV_PROJECT_ENVIRONMENT="/app/.venv"

EXPOSE 8000

CMD ["litestar", "run", "--reload", "--host", "0.0.0.0", "--port", "8000"]